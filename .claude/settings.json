{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "mcp__github__*",
      "mcp__gitnexus__*",
      "mcp__chrome-devtools__*"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep|Glob|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y gitnexus@latest augment",
            "timeout": 8000,
            "statusMessage": "GitNexus: enriching with graph context..."
          }
        ]
      }
    ]
  }
}